DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=footlink
JWT_SECRET=secret123
//DB_HOST → adresse de ta base de données (localhost si c’est sur ton PC)
//DB_USER → nom d’utilisateur de ta base de données (root par défaut)
//DB_PASSWORD → mot de passe de ta base de données (vide par défaut)
//DB_NAME → nom de ta base de données (footlink dans notre cas)
//JWT_SECRET → secret pour signer les tokens JWT (choisis une valeur secrète)